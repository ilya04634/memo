rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboard/{uid} {
      allow read: if true;
      allow create, update: if
        request.auth != null &&
        request.auth.uid == uid &&
        request.resource.data.keys().hasOnly(['name','timeMs','moves','createdAt','updatedAt']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 16 &&
        request.resource.data.timeMs is int &&
        request.resource.data.timeMs >= 0 &&
        request.resource.data.timeMs < 3600000 &&
        request.resource.data.moves is int &&
        request.resource.data.moves >= 0 &&
        request.resource.data.moves < 9999;
      allow delete: if false;
    }

    match /rooms/{code} {
      allow list: if false;
      allow get: if request.auth != null;

      allow create: if
        request.auth != null &&
        request.resource.data.keys().hasOnly([
          'code','difficulty','maxPlayers','hostUid','status','seed','startAt','createdAt','updatedAt'
        ]) &&
        request.resource.data.code is string &&
        request.resource.data.code == code &&
        request.resource.data.difficulty is string &&
        request.resource.data.maxPlayers is int &&
        request.resource.data.maxPlayers >= 2 &&
        request.resource.data.maxPlayers <= 20 &&
        request.resource.data.hostUid is string &&
        request.resource.data.hostUid == request.auth.uid &&
        request.resource.data.status is string &&
        request.resource.data.seed is int;

      allow update: if
        request.auth != null &&
        request.auth.uid == resource.data.hostUid &&
        request.resource.data.keys().hasOnly([
          'code','difficulty','maxPlayers','hostUid','status','seed','startAt','createdAt','updatedAt'
        ]) &&
        resource.data.hostUid is string &&
        resource.data.code == code &&
        request.resource.data.code == resource.data.code &&
        request.resource.data.hostUid == resource.data.hostUid &&
        request.resource.data.difficulty == resource.data.difficulty &&
        request.resource.data.maxPlayers == resource.data.maxPlayers &&
        request.resource.data.seed == resource.data.seed &&
        request.resource.data.status is string;

      allow delete: if false;
    }

    match /rooms/{code}/players/{uid} {
      // Only room members can see the lobby players list.
      allow list, get: if
        request.auth != null &&
        exists(/databases/$(database)/documents/rooms/$(code)/players/$(request.auth.uid));

      allow create: if
        request.auth != null &&
        request.auth.uid == uid &&
        request.resource.data.keys().hasOnly(['uid','nick','moves','timeMs','finishedAt','joinedAt','updatedAt']) &&
        request.resource.data.uid is string &&
        request.resource.data.uid == uid &&
        request.resource.data.nick is string &&
        request.resource.data.nick.size() >= 2 &&
        request.resource.data.nick.size() <= 16 &&
        request.resource.data.moves is int &&
        request.resource.data.moves >= 0 &&
        request.resource.data.moves < 9999;

      allow update: if
        request.auth != null &&
        request.auth.uid == uid &&
        request.resource.data.keys().hasOnly(['uid','nick','moves','timeMs','finishedAt','joinedAt','updatedAt']) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.nick is string &&
        request.resource.data.nick.size() >= 2 &&
        request.resource.data.nick.size() <= 16 &&
        request.resource.data.moves is int &&
        request.resource.data.moves >= 0 &&
        request.resource.data.moves < 9999;

      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
